# Single configuration file: copy to `.env` on the Docker host (same folder as docker-compose.yml).
# Paste equivalent keys into Portainer stack environment if you do not mount a `.env` file.
# Never commit the real `.env`.
#
# --- Portainer "stack from Git" ---
# Omit IAC_REPO_PATH and SSH_KEY_PATH unless you need a manual repo path or OpenTofu SSH key.
#
# --- OpenTofu ---

TF_VAR_proxmox_endpoint=https://pve01.example.internal:8006/
TF_VAR_proxmox_api_token=terraform@pve!iac=REPLACE_ME
TF_VAR_proxmox_node=pve01
TF_VAR_datastore=local-lvm
TF_VAR_win11_template_id=9025
TF_VAR_vm_id=1101
TF_VAR_vm_name=win11-dev-01
TF_VAR_bridge=vmbr0

# Packer — HashiCorp reads PKR_VAR_<variable_name> from the environment (no separate .pkrvars file).
# Token is shared with OpenTofu: proxmox_token defaults to TF_VAR_proxmox_api_token in win11.pkr.hcl.
PKR_VAR_proxmox_url=https://pve01.example.internal:8006/api2/json
PKR_VAR_proxmox_node=pve01
PKR_VAR_proxmox_username=terraform@pve
PKR_VAR_template_vm_id=9025
PKR_VAR_template_name=tpl-win11-25h2-dev
PKR_VAR_iso_file=local:iso/Win11_25H2_English_x64.iso
PKR_VAR_virtio_iso_file=local:iso/virtio-win.iso
PKR_VAR_vm_storage=local-lvm
PKR_VAR_iso_storage=local
PKR_VAR_bridge=vmbr0
PKR_VAR_winrm_username=packer

# Keep PKR_VAR_bridge in sync with TF_VAR_bridge when they describe the same VM network.

# Packer WinRM password (match packer/answer/Autounattend.xml local account password)
WINRM_PASSWORD=REPLACE_ME

# Ansible WinRM (devadmin or your ansible_user)
WINDOWS_ADMIN_PASSWORD=REPLACE_ME

# --- Optional compose-only ---
# IAC_REPO_PATH=/opt/stacks/proxmox-win11-dev-iac
# SSH_KEY_PATH=/home/youruser/.ssh/id_rsa

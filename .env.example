# Copy into Portainer stack environment (or .env on host); never commit real secrets.
#
# --- Portainer "stack from Git" (typical) ---
# You do NOT need IAC_REPO_PATH or SSH_KEY_PATH:
#   • Workspace bind mount uses `.` = Portainer’s checkout directory (repo root on host).
#   • Omit SSH_KEY_PATH for Proxmox API-token-only auth (typical for OpenTofu).
# Enter only the variables below (plus secrets).

PROXMOX_URL=https://pve01.example.internal:8006/api2/json
PROXMOX_USERNAME=terraform@pve
PROXMOX_TOKEN=terraform@pve!iac=REPLACE_ME

TF_VAR_proxmox_endpoint=https://pve01.example.internal:8006/
TF_VAR_proxmox_api_token=terraform@pve!iac=REPLACE_ME
TF_VAR_proxmox_node=pve01
TF_VAR_datastore=local-lvm
TF_VAR_win11_template_id=9025
TF_VAR_vm_id=1101
TF_VAR_vm_name=win11-dev-01
TF_VAR_bridge=vmbr0

# --- Optional (skip for Git-based stack above) ---
# IAC_REPO_PATH=/opt/stacks/proxmox-win11-dev-iac   # manual clone: absolute path to repo root
# SSH_KEY_PATH=/home/youruser/.ssh/id_rsa          # only if OpenTofu needs host SSH key

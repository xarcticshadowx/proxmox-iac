# Single configuration source of truth: copy keys below into either —
#   • Portainer: Stack → Environment (recommended for Git stacks — `.env` is not in Git), or
#   • A file named `.env` next to docker-compose.yml on the Docker host (optional; gitignored).
# Uploading a file in the Portainer UI does not create `/.env` on disk; use Environment fields instead.
# docker-compose.yml lists each variable under `environment: VAR: ${VAR}` so Portainer injects them into containers.
# Never commit the real `.env`.
#
# --- Portainer "stack from Git" ---
# Omit IAC_REPO_PATH and SSH_KEY_PATH unless you need a manual repo path or OpenTofu SSH key.
#
# --- OpenTofu ---

TF_VAR_proxmox_endpoint=https://pve01.example.internal:8006/
# Full token: user@realm!tokenid=uuid-secret (required for API; Packer and OpenTofu both need this)
TF_VAR_proxmox_api_token=terraform@pve!iac=REPLACE_ME
TF_VAR_proxmox_node=pve01
TF_VAR_datastore=local-lvm
TF_VAR_win11_template_id=9025
TF_VAR_vm_id=1101
TF_VAR_vm_name=win11-dev-01
TF_VAR_bridge=vmbr0

# Packer — HashiCorp reads PKR_VAR_<variable_name> from the environment (no separate .pkrvars file).
# API token: normally TF_VAR_proxmox_api_token above; optional duplicate here if Packer needs PKR_VAR_* only.
PKR_VAR_proxmox_token=
PKR_VAR_proxmox_url=https://pve01.example.internal:8006/api2/json
PKR_VAR_proxmox_node=pve01
PKR_VAR_proxmox_username=terraform@pve
PKR_VAR_template_vm_id=9025
PKR_VAR_template_name=tpl-win11-25h2-dev
PKR_VAR_iso_file=local:iso/Win11_25H2_English_x64.iso
# Extra opticals — choose ONE: (A) merged ISO, OR (B) stock virtio + cidata-only (unset supplemental for B).
# (A) Merged virtio-win + unattend/scripts (build: packer/scripts/build-supplemental-iso.sh).
PKR_VAR_supplemental_iso_file=local:iso/supplemental.iso
# (B) Split: upload Fedora virtio-win.iso + cidata.iso from build-cidata-only-iso.sh — leave supplemental empty and set both lines:
# PKR_VAR_supplemental_iso_file=
# PKR_VAR_virtio_iso_file=local:iso/virtio-win-0.1.262.iso
# PKR_VAR_cidata_iso_file=local:iso/cidata.iso
# Rare: set true only if you changed VM disk/controller to use WinPE inbox drivers (see win11.pkr.hcl).
# PKR_VAR_allow_build_without_supplemental_iso=true
PKR_VAR_vm_storage=local-lvm
PKR_VAR_bridge=vmbr0
PKR_VAR_winrm_username=packer
# Image index for unattend (verify with dism /Get-WimInfo /WimFile:...\sources\install.esd or install.wim)
PKR_VAR_win11_install_wim_index=6
# Full/VL ISOs often use install.wim (verify on ISO volume e.g. F:\sources\). MCT retail ISOs may use install.esd only.
PKR_VAR_win11_install_filename=install.wim
# VirtIO vioscsi folder on supplemental ISO (forward slashes OK). Verify under your virtio-win.iso (e.g. w11, 2k22).
PKR_VAR_virtio_vioscsi_rel_path=vioscsi/w11/amd64
# Optional: exact "Name" from `dism /Get-WimInfo /WimFile:<DVD>:\sources\install.wim` — overrides index when set (fixes wrong edition index / 0x80070002).
# PKR_VAR_win11_install_image_name=Windows 11 Pro

# Keep PKR_VAR_bridge in sync with TF_VAR_bridge when they describe the same VM network.

# Packer WinRM password — injected into packer/answer/Autounattend.xml by render-autounattend.* (must match)
WINRM_PASSWORD=REPLACE_ME

# Ansible WinRM (devadmin or your ansible_user)
WINDOWS_ADMIN_PASSWORD=REPLACE_ME

# --- Optional compose-only ---
# IAC_REPO_PATH=/opt/stacks/proxmox-win11-dev-iac
# SSH_KEY_PATH=/home/youruser/.ssh/id_rsa

# --- Troubleshooting Packer "401 Unauthorized" ---
# 1) Inside iac-packer at least one must be set: TF_VAR_proxmox_api_token or PKR_VAR_proxmox_token (same full token).
# 2) Token must include the secret: user@realm!tokenname=secret-uuid (create/copy in Proxmox UI).
# 3) PKR_VAR_proxmox_username must match the user in the token (e.g. arctic@pam).
